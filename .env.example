DB_MODE=auto
ALLOW_FILE_FALLBACK=true
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pos?appName=Cluster1
JWT_SECRET=change-this-to-a-long-random-string
PORT=3002

# Silent thermal printing (local POS only — not on Vercel)
SILENT_PRINT=true
# Exact printer name from OS (optional; uses default if empty)
# Linux: run `lpstat -p`   Windows: Settings → Printers
RECEIPT_PRINTER=
